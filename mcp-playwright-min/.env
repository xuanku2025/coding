# Output directory for screenshots/PDFs
OUTPUT_DIR=/Users/enyousun/Desktop/coding/mcp-playwright-min/output
# Headless mode: true/false
HEADLESS=false
# Ignore HTTPS errors (self-signed certs)
IGNORE_HTTPS_ERRORS=true

# Login config (required for login_and_capture)
LOGIN_URL=https://172.27.52.233/login
LOGIN_USER=your_admin
LOGIN_PASS=your_password

# Selectors (CSS)
SELECTOR_USER='[data-testid="username"]'
SELECTOR_PASS='[data-testid="password"]'
SELECTOR_SUBMIT='#login'
# A selector that only appears after login succeeds (recommended)
SELECTOR_READY='#root-master'

# Cookie storage state for auth reuse
STORAGE_STATE=/Users/enyousun/Desktop/coding/mcp-playwright-min/storage-state.json
