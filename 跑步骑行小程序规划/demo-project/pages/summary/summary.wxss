.container { padding: 40px 20px 20px 20px; background: #fff; height: 100vh; box-sizing: border-box; }
.top-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; font-weight: bold; }
.back-btn, .done-btn { color: #007aff; }
.hero-card { position: relative; width: 100%; height: 400px; border-radius: 20px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.1); margin-bottom: 30px; }
.card-bg { width: 100%; height: 100%; position: absolute; z-index: 1; }
.card-overlay { position: absolute; width: 100%; height: 100%; background: linear-gradient(to bottom, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0.7) 100%); z-index: 2; }
.card-content { position: absolute; bottom: 20px; left: 20px; right: 20px; z-index: 3; color: white; }
.date { font-size: 14px; opacity: 0.8; margin-bottom: 10px; }
.main-stats { display: flex; align-items: baseline; margin-bottom: 20px; }
.dist { font-size: 64px; font-weight: 900; line-height: 1; }
.unit { font-size: 18px; margin-left: 5px; }
.sub-stats { display: flex; justify-content: space-between; }
.stat-item { display: flex; flex-direction: column; }
.val { font-size: 20px; font-weight: bold; }
.lbl { font-size: 12px; opacity: 0.8; }
.share-actions { display: flex; flex-direction: column; gap: 15px; }
.share-btn { width: 100%; height: 50px; border-radius: 25px; display: flex; justify-content: center; align-items: center; font-size: 16px; font-weight: bold; border: none; }
.share-btn.wx { background: #07c160; color: white; }
.share-btn.poster { background: #f0f0f0; color: #333; }
