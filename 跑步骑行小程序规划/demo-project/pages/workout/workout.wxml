<view class="container">
  <!-- Top Data Panel -->
  <view class="data-panel {{sportType}}">
    <view class="main-data">{{timeStr}}</view>
    <view class="sub-data">
      <view class="item">
        <text class="value">{{distance}}</text>
        <text class="label">公里</text>
      </view>
      <view class="item">
        <text class="value">{{pace}}</text>
        <text class="label" wx:if="{{sportType === 'run'}}">配速 (分/公里)</text>
        <text class="label" wx:if="{{sportType === 'ride'}}">速度 (公里/时)</text>
      </view>
    </view>
  </view>

  <!-- Mid Map -->
  <map class="workout-map" latitude="{{latitude}}" longitude="{{longitude}}" polyline="{{polyline}}" show-location scale="17"></map>

  <!-- Bottom Control -->
  <view class="control-panel">
    <view class="btn pause" bindtap="pauseWorkout">{{isPaused ? '继续' : '暂停'}}</view>
    <view class="btn end" bindlongpress="endWorkout">长按结束</view>
  </view>
</view>
