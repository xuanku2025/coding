.container { display: flex; flex-direction: column; height: 100vh; }
.data-panel { flex: 0 0 30%; display: flex; flex-direction: column; align-items: center; justify-content: center; color: white; padding-top: 40px; }
.data-panel.run { background: linear-gradient(135deg, #ff9a44, #fc6076); }
.data-panel.ride { background: linear-gradient(135deg, #00c6ff, #0072ff); }
.main-data { font-size: 72px; font-weight: 900; font-variant-numeric: tabular-nums; line-height: 1; margin-bottom: 20px; }
.sub-data { display: flex; width: 100%; justify-content: space-around; }
.item { display: flex; flex-direction: column; align-items: center; }
.value { font-size: 36px; font-weight: bold; }
.label { font-size: 14px; opacity: 0.8; }
.workout-map { flex: 1; width: 100%; }
.control-panel { flex: 0 0 20%; display: flex; justify-content: space-around; align-items: center; background: white; border-top-left-radius: 30px; border-top-right-radius: 30px; margin-top: -20px; z-index: 10; padding-bottom: 20px; box-shadow: 0 -5px 15px rgba(0,0,0,0.1); }
.btn { width: 100px; height: 100px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20px; font-weight: bold; color: white; cursor: pointer; transition: transform 0.2s; }
.btn:active { transform: scale(0.95); }
.pause { background: #f39c12; }
.end { background: #e74c3c; }
