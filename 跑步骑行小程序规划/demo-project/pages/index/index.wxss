.container { position: relative; }
.map-bg { width: 100vw; height: 100vh; position: absolute; top: 0; left: 0; z-index: 1; }
.top-status { position: absolute; top: 40px; left: 20px; right: 20px; display: flex; justify-content: space-between; z-index: 10; font-size: 14px; font-weight: bold; background: rgba(255,255,255,0.8); padding: 5px 15px; border-radius: 20px; }
.type-toggle { position: absolute; top: 100px; left: 50%; transform: translateX(-50%); display: flex; background: rgba(0,0,0,0.5); border-radius: 30px; padding: 5px; z-index: 10; }
.toggle-item { padding: 10px 30px; color: white; font-weight: bold; border-radius: 25px; transition: all 0.3s; }
.active-run { background: #ff6b00; }
.active-ride { background: #0088ff; }
.start-panel { position: absolute; bottom: 80px; width: 100%; display: flex; justify-content: center; z-index: 10; }
.start-btn { width: 120px; height: 120px; border-radius: 60px; font-size: 36px; font-weight: 900; color: white; display: flex; align-items: center; justify-content: center; box-shadow: 0 10px 20px rgba(0,0,0,0.3); }
.start-btn.run { background: linear-gradient(135deg, #ff9a44, #fc6076); }
.start-btn.ride { background: linear-gradient(135deg, #00c6ff, #0072ff); }
