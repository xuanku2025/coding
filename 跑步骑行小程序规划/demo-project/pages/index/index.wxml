<view class="container">
  <!-- Map Background -->
  <map id="myMap" class="map-bg" latitude="{{latitude}}" longitude="{{longitude}}" scale="16" show-location></map>

  <!-- Top Status -->
  <view class="top-status">
    <view class="gps-signal">GPS: 优</view>
    <view class="weather">25°C 晴</view>
  </view>

  <!-- Type Toggle -->
  <view class="type-toggle">
    <view class="toggle-item {{sportType === 'run' ? 'active-run' : ''}}" bindtap="switchType" data-type="run">跑步</view>
    <view class="toggle-item {{sportType === 'ride' ? 'active-ride' : ''}}" bindtap="switchType" data-type="ride">骑行</view>
  </view>

  <!-- Main Start Button -->
  <view class="start-panel">
    <button class="start-btn {{sportType}}" bindtap="startWorkout">GO</button>
  </view>
</view>
