.container { padding: 40px 20px 20px 20px; background: #f7f7f7; min-height: 100vh; box-sizing: border-box; }
.user-header { display: flex; flex-direction: column; align-items: center; margin-bottom: 30px; }
.avatar { width: 80px; height: 80px; border-radius: 40px; border: 3px solid white; box-shadow: 0 5px 15px rgba(0,0,0,0.1); margin-bottom: 15px; }
.nickname { font-size: 20px; font-weight: bold; margin-bottom: 5px; }
.days-active { font-size: 14px; color: #888; }
.total-stats { display: flex; justify-content: space-between; margin-bottom: 30px; gap: 15px; }
.stat-box { flex: 1; padding: 20px; border-radius: 15px; color: white; display: flex; flex-direction: column; align-items: center; box-shadow: 0 5px 15px rgba(0,0,0,0.1); }
.stat-box.run { background: linear-gradient(135deg, #ff9a44, #fc6076); }
.stat-box.ride { background: linear-gradient(135deg, #00c6ff, #0072ff); }
.stat-box .val { font-size: 32px; font-weight: 900; margin-bottom: 5px; }
.stat-box .lbl { font-size: 14px; opacity: 0.8; }
.history-list { background: white; border-radius: 20px; padding: 20px; box-shadow: 0 5px 15px rgba(0,0,0,0.05); margin-bottom: 20px; }
.month-title { font-size: 18px; font-weight: bold; margin-bottom: 15px; padding-bottom: 10px; border-bottom: 1px solid #eee; }
.history-item { display: flex; align-items: center; margin-bottom: 20px; }
.history-item:last-child { margin-bottom: 0; }
.icon { width: 40px; height: 40px; border-radius: 20px; display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; margin-right: 15px; }
.run-icon { background: #ff6b00; }
.ride-icon { background: #0088ff; }
.info { flex: 1; }
.info .title { font-size: 16px; font-weight: bold; color: #333; margin-bottom: 5px; }
.info .desc { font-size: 13px; color: #888; }
.dist { font-size: 22px; font-weight: bold; color: #333; }
.dist .unit { font-size: 12px; color: #888; }
.settings { background: white; border-radius: 20px; padding: 20px; box-shadow: 0 5px 15px rgba(0,0,0,0.05); }
.setting-item { display: flex; justify-content: space-between; align-items: center; font-size: 16px; font-weight: bold; }
