# ============================================================
# Legacy Atlassian MCP Server - 环境变量配置
# 复制此文件为 .env 并填入真实值（不要提交到 git！）
# ============================================================

# Confluence 6.x 内网地址（末尾不加 /）
CONFLUENCE_URL=http://192.168.x.x:8090
CONFLUENCE_USER=your_username
CONFLUENCE_PASS=your_password

# Jira 8.x 内网地址（末尾不加 /）
JIRA_URL=http://192.168.x.x:8080
JIRA_USER=your_username
JIRA_PASS=your_password
