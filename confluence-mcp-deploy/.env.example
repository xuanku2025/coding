# Confluence 内网地址（不要加末尾斜杠）
CONFLUENCE_URL=http://confluence.zstack.io

# 登录用户名
CONFLUENCE_USERNAME=enyou.sun

# 方式一（旧版 Confluence / 许可证过期时）：填你的 Confluence 登录密码
# 官方文档：For older Confluence servers, try basic auth with CONFLUENCE_API_TOKEN (where token is your password)
CONFLUENCE_API_TOKEN=

# 方式二（若有可用 Token）：在 个人设置 → API Tokens / Personal Access Tokens 创建后填这里
# CONFLUENCE_PERSONAL_TOKEN=

# 内网 HTTP 时可关闭 SSL 校验（可选）
CONFLUENCE_SSL_VERIFY=false

# ============ Jira（可选；填了才会启用 Jira 工具） ============
# Jira（用户名+密码 / Basic Auth）：
# - 适用：多数 Jira Server/Data Center（具体取决于你们实例的安全策略）
# - 写法：把“密码”填在 JIRA_API_TOKEN（变量名叫 token，但可放密码）
# JIRA_URL=http://jira.your-company.com
# JIRA_USERNAME=your.username
# JIRA_API_TOKEN=你的登录密码
#
# Jira Cloud 通常不接受账号密码直连，请使用 API Token：
# JIRA_URL=https://your-company.atlassian.net
# JIRA_USERNAME=your.email@company.com
# JIRA_API_TOKEN=你的_cloud_api_token
#
# Jira Server/Data Center（推荐）：PAT
# JIRA_URL=https://jira.your-company.com
# JIRA_PERSONAL_TOKEN=
#
# 自签证书/企业 CA 未加入系统信任链时可关闭校验（可选）
# JIRA_SSL_VERIFY=false

# MCP 服务端口
MCP_PORT=9090

# 可选：调试日志
# MCP_VERBOSE=true
# MCP_VERY_VERBOSE=true
# MCP_LOGGING_STDOUT=true
