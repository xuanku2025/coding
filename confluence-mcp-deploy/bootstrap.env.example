# 一键部署脚本的非交互配置模板（不要提交含密码的 bootstrap.env）
#
# 用法：
#   cp bootstrap.env.example bootstrap.env
#   vi bootstrap.env
#   scp -r confluence-mcp-deploy root@<vm_ip>:~/confluence-mcp-deploy
#   ssh root@<vm_ip>
#   cd ~/confluence-mcp-deploy && chmod +x bootstrap-deploy.sh
#   ./bootstrap-deploy.sh --config ./bootstrap.env --non-interactive
#

# ===== 必填：Confluence（用户名+密码）=====
CONFLUENCE_URL="http://confluence.zstack.io"
CONFLUENCE_USERNAME="your_confluence_username"
CONFLUENCE_PASSWORD="your_confluence_password"
CONFLUENCE_SSL_VERIFY="false"

# ===== 可选：Jira（用户名+密码）=====
# 启用 Jira：true/false
JIRA_ENABLE="true"
JIRA_URL="http://jira.your-company.com"
JIRA_USERNAME="your_jira_username"
JIRA_PASSWORD="your_jira_password"
JIRA_SSL_VERIFY="false"

# ===== 必填：宿主机端口（映射到容器 9090）=====
MCP_HOST_PORT="9092"

# ===== 可选：钉钉机器人通知 =====
# 不需要通知就留空
DINGTALK_WEBHOOK=""
# 开启“加签”才需要
DINGTALK_SECRET=""

