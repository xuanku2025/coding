# 这是要填写的“唯一配置文件”（含密码！不要提交到 Git）
#
# 使用方法（在虚拟机上）：
#   cp bootstrap.env.example bootstrap.env
#   chmod 600 bootstrap.env
#   ./bootstrap-deploy.sh --config ./bootstrap.env --non-interactive
#

# ===== 必填：Confluence（用户名+密码）=====
CONFLUENCE_URL="http://confluence.zstack.io"
CONFLUENCE_USERNAME=""
CONFLUENCE_PASSWORD=""
CONFLUENCE_SSL_VERIFY="false"

# ===== 可选：Jira（用户名+密码）=====
# 默认关闭，避免忘填账号导致非交互部署失败；需要 Jira 再改为 true
JIRA_ENABLE="false"
JIRA_URL="http://jira.your-company.com"
JIRA_USERNAME=""
JIRA_PASSWORD=""
JIRA_SSL_VERIFY="false"

# ===== 必填：宿主机端口（映射到容器 9090）=====
MCP_HOST_PORT="19092"

# ===== 可选：钉钉机器人通知 =====
DINGTALK_WEBHOOK=""
DINGTALK_SECRET=""

