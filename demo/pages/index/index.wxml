<view class="container index-container">
  <!-- 顶部状态栏及运动类型切换 -->
  <view class="header-area">
    <view class="status-bar">
      <text class="gps-status signal-good">🛰 GPS 强</text>
      <text class="weather-info">☀️ 晴 26°C</text>
    </view>

    <view class="sport-type-switch">
      <view class="switch-item {{sportType === 'running' ? 'active' : ''}}" bindtap="switchSport" data-type="running">跑步</view>
      <view class="switch-item {{sportType === 'cycling' ? 'active' : ''}}" bindtap="switchSport" data-type="cycling">骑行</view>
    </view>

    <view class="sport-stats">
      <view class="stat-item">
        <text class="stat-value">12.5</text>
        <text class="stat-label">本周公里</text>
      </view>
    </view>
  </view>

  <!-- 全屏地图区域 -->
  <view class="map-area">
    <map id="homeMap"
         class="main-map"
         longitude="116.39750"
         latitude="39.90850"
         scale="16"
         show-location="true"
         enable-scroll="false"
         enable-zoom="false">
    </map>
    <!-- 渐变遮罩层，让底部操作区更清晰 -->
    <view class="map-gradient-bottom"></view>
  </view>

  <!-- 底部操作区 -->
  <view class="action-area">
    <button class="btn-start" bindtap="startWorkout">
      <text class="btn-text">GO</text>
      <text class="btn-subtext">开始{{sportType === 'running' ? '跑步' : '骑行'}}</text>
    </button>
  </view>
</view>
