/* pages/summary/summary.wxss */
.summary-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f7f8fa;
}

.nav-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 50px 20px 10px; /* 适配状态栏 */
  background-color: #fff;
  border-bottom: 1px solid #f0f0f0;
}

.nav-btn {
  font-size: 16px;
  color: #333;
  padding: 10px;
}

.icon-back {
  margin-right: 4px;
}

.text-primary {
  color: #07c160;
  font-weight: 500;
}

.nav-title {
  font-size: 18px;
  font-weight: 600;
  color: #000;
}

.summary-content {
  flex: 1;
  padding: 20px;
  box-sizing: border-box;
}

/* 核心卡片 */
.card-area {
  background-color: #fff;
  border-radius: 24px;
  overflow: hidden;
  box-shadow: 0 8px 30px rgba(0,0,0,0.06);
  margin-bottom: 30px;
}

.map-snapshot {
  height: 240px;
  position: relative;
  background-color: #e9e9e9;
  display: flex;
  justify-content: center;
  align-items: center;
}

.placeholder-img {
  width: 40px;
  height: 40px;
  opacity: 0.2;
}

.snapshot-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0) 60%);
}

.core-stats {
  position: absolute;
  bottom: 20px;
  left: 20px;
  color: #fff;
  text-shadow: 0 2px 4px rgba(0,0,0,0.3);
}

.distance-val {
  font-size: 64px;
  font-weight: 800;
  font-family: 'DIN Alternate', -apple-system;
  line-height: 1;
  margin-bottom: 4px;
}

.distance-unit {
  font-size: 20px;
  font-weight: 500;
  margin-left: 4px;
}

.sport-date {
  font-size: 14px;
  opacity: 0.9;
}

.stats-grid {
  display: flex;
  padding: 24px 10px;
}

.stat-box {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-right: 1px solid #f0f0f0;
}

.stat-box:last-child {
  border-right: none;
}

.sb-val {
  font-size: 24px;
  font-weight: 700;
  font-family: 'DIN Alternate', -apple-system;
  color: #333;
  margin-bottom: 8px;
}

.sb-lbl {
  font-size: 12px;
  color: #999;
}

/* 详情列表 */
.details-section {
  background-color: #fff;
  border-radius: 20px;
  padding: 24px 20px;
  margin-bottom: 30px;
}

.section-title {
  font-size: 18px;
  font-weight: 600;
  margin-bottom: 20px;
  color: #000;
}

.split-item {
  display: flex;
  align-items: center;
  margin-bottom: 16px;
  font-size: 14px;
}

.split-item:last-child {
  margin-bottom: 0;
}

.split-km {
  width: 50px;
  color: #666;
  font-weight: 500;
}

.split-bar-container {
  flex: 1;
  height: 8px;
  background-color: #f5f5f5;
  border-radius: 4px;
  margin: 0 16px;
  overflow: hidden;
}

.split-bar {
  height: 100%;
  border-radius: 4px;
  transition: width 0.5s ease;
}

.split-pace {
  width: 50px;
  text-align: right;
  font-family: 'DIN Alternate', -apple-system;
  font-weight: 700;
  color: #333;
}

.bottom-spacer {
  height: 100px;
}

/* 悬浮操作 */
.share-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 16px 20px 30px; /* 包含大系统底部安全区 */
  background: rgba(255,255,255,0.9);
  backdrop-filter: blur(10px);
  display: flex;
  box-sizing: border-box;
  box-shadow: 0 -4px 20px rgba(0,0,0,0.03);
}

.btn-share-wx {
  flex: 1;
  height: 50px;
  border-radius: 25px;
  background-color: #07c160;
  color: white;
  font-size: 16px;
  font-weight: 500;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 12px;
}

.btn-share-poster {
  flex: 1;
  height: 50px;
  border-radius: 25px;
  background-color: #f0f0f0;
  color: #333;
  font-size: 16px;
  font-weight: 500;
  display: flex;
  justify-content: center;
  align-items: center;
}
