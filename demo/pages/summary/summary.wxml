<!-- pages/summary/summary.wxml -->
<view class="container summary-container">
  <!-- 顶部导航 -->
  <view class="nav-bar">
    <view class="nav-btn" bindtap="goHome">
      <text class="icon-back">←</text> 返回
    </view>
    <view class="nav-title">运动记录</view>
    <view class="nav-btn text-primary" bindtap="goHome">完成</view>
  </view>

  <scroll-view class="summary-content" scroll-y>
    <!-- 头部地图卡片 -->
    <view class="card-area">
      <!-- 模拟一张带轨迹的地图图片 -->
      <view class="map-snapshot">
        <image src="/images/tab_sport.png" class="placeholder-img"></image>
        <view class="snapshot-overlay"></view>

        <!-- 叠加在地图上的核心数据 -->
        <view class="core-stats">
          <view class="distance-val">2.54<text class="distance-unit">km</text></view>
          <view class="sport-date">2026年3月4日 傍晚跑步</view>
        </view>
      </view>

      <!-- 数据细分网格 -->
      <view class="stats-grid">
        <view class="stat-box">
          <text class="sb-val">15:20</text>
          <text class="sb-lbl">时长</text>
        </view>
        <view class="stat-box">
          <text class="sb-val">6'02"</text>
          <text class="sb-lbl">配速</text>
        </view>
        <view class="stat-box">
          <text class="sb-val">120</text>
          <text class="sb-lbl">千卡</text>
        </view>
      </view>
    </view>

    <!-- 图表和分段列表区 -->
    <view class="details-section">
      <view class="section-title">配速分段</view>
      <view class="splits-list">
        <view class="split-item" wx:for="{{[1,2,3]}}" wx:key="*this">
          <view class="split-km">{{item}} km</view>
          <view class="split-bar-container">
            <!-- 模拟不同长度的柱状图 -->
            <view class="split-bar" style="width: {{60 + item * 10}}%; background-color: {{item === 2 ? '#07c160' : '#d2f3e0'}}"></view>
          </view>
          <view class="split-pace">5'{{40 + item * 10}}"</view>
        </view>
      </view>
    </view>

    <!-- 底部站位防遮挡 -->
    <view class="bottom-spacer"></view>
  </scroll-view>

  <!-- 底部悬浮分享操作 -->
  <view class="share-actions">
    <button class="btn-share-wx" open-type="share">分享给好友</button>
    <button class="btn-share-poster">生成长图</button>
  </view>
</view>
