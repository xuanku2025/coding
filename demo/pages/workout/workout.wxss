/* pages/workout/workout.wxss */
.workout-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #000; /* 高对比度深色模式更有运动感 */
}

/* 顶部数据区 */
.data-panel {
  flex: 0 0 30%;
  padding: 60px 20px 20px; /* 适配状态栏 */
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  background-color: #111;
  color: #fff;
}

.time-display {
  margin-bottom: 20px;
}

.time-value {
  font-size: 72px;
  font-weight: 800;
  font-family: 'DIN Alternate', -apple-system;
  color: #fff;
  line-height: 1;
  letter-spacing: -2px;
}

.sub-data-row {
  display: flex;
  width: 100%;
  justify-content: space-around;
}

.data-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.data-val {
  font-size: 32px;
  font-weight: 700;
  font-family: 'DIN Alternate', -apple-system;
  margin-bottom: 4px;
}

.data-lbl {
  font-size: 12px;
  color: #888;
}

/* 中间地图区 */
.map-area {
  flex: 1;
  position: relative;
  overflow: hidden;
  border-radius: 20px 20px 0 0;
  background-color: #333;
}

.workout-map {
  width: 100%;
  height: 100%;
}

/* 底部操作区 */
.control-panel {
  flex: 0 0 25%;
  background-color: #111;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding-bottom: env(safe-area-inset-bottom);
}

.btn-pause {
  width: 90px;
  height: 90px;
  border-radius: 50%;
  background-color: #f0f0f0;
  color: #333;
  display: flex;
  justify-content: center;
  align-items: center;
  border: none;
  margin-bottom: 15px;
  box-shadow: 0 4px 15px rgba(255,255,255,0.1);
}

.icon-pause {
  font-size: 36px;
  font-weight: 900;
  transform: scale(0.8, 1.2);
}

.paused-controls {
  display: flex;
  width: 100%;
  justify-content: space-evenly;
}

.control-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.btn-resume {
  width: 90px;
  height: 90px;
  border-radius: 50%;
  background-color: #07c160;
  color: white;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 10px;
  box-shadow: 0 4px 15px rgba(7, 193, 96, 0.3);
}

.icon-resume {
  font-size: 36px;
  margin-left: 6px; /* 让三角居中 */
}

.btn-finish {
  width: 90px;
  height: 90px;
  border-radius: 50%;
  background-color: #fa5151;
  color: white;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 10px;
  box-shadow: 0 4px 15px rgba(250, 81, 81, 0.3);
}

.icon-finish {
  font-size: 32px;
}

.hint-text {
  font-size: 12px;
  color: #888;
}
