<!-- pages/workout/workout.wxml -->
<view class="container workout-container">
  <!-- 顶部数据面板 -->
  <view class="data-panel">
    <view class="time-display">
      <text class="time-value">{{formattedTime}}</text>
    </view>

    <view class="sub-data-row">
      <view class="data-item">
        <text class="data-val">2.54</text>
        <text class="data-lbl">公里</text>
      </view>
      <view class="data-item">
        <text class="data-val">120</text>
        <text class="data-lbl">千卡</text>
      </view>
      <view class="data-item">
        <text class="data-val">5'30"</text>
        <text class="data-lbl">{{sportType === 'running' ? '配速' : '速度(km/h)'}}</text>
      </view>
    </view>
  </view>

  <!-- 中间地图区域 -->
  <view class="map-area">
    <map id="workoutMap"
         class="workout-map"
         longitude="116.39750"
         latitude="39.90850"
         scale="18"
         show-location="true"
         enable-scroll="true"
         enable-zoom="true">
    </map>
  </view>

  <!-- 底部操作区 -->
  <view class="control-panel">
    <!-- 未暂停状态: 显示暂停按钮 -->
    <block wx:if="{{!isPaused}}">
      <button class="btn-pause" bindtap="togglePause">
        <text class="icon-pause">||</text>
      </button>
      <text class="hint-text">点击暂停</text>
    </block>

    <!-- 暂停状态: 显示继续和结束按钮 -->
    <block wx:else>
      <view class="paused-controls">
        <view class="control-item">
          <button class="btn-resume" bindtap="togglePause">
            <text class="icon-resume">▶</text>
          </button>
          <text class="hint-text">继续</text>
        </view>
        <view class="control-item">
          <button class="btn-finish" bindlongpress="finishWorkout">
            <text class="icon-finish">■</text>
          </button>
          <text class="hint-text">长按结束</text>
        </view>
      </view>
    </block>
  </view>
</view>
