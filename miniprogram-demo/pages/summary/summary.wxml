<!--pages/summary/summary.wxml-->
<view class="container summary-page">

  <!-- Navigation Setup -->
  <view class="nav-bar">
    <view class="nav-btn" bindtap="goHome">
      <icon type="clear" size="24" color="white"></icon>
    </view>
    <view class="nav-title">运动记录</view>
    <view class="nav-btn" bindtap="goHome">
      <text class="finish-text">完成</text>
    </view>
  </view>

  <!-- Hero Achievement Map Area -->
  <view class="hero-section shadow-lg">
    <view class="map-bg">
      <map id="summaryMap" longitude="116.40717" latitude="39.90469" scale="15" show-location="false"></map>
      <view class="map-overlay"></view>
    </view>
    
    <view class="hero-data">
      <view class="date-tag">{{summary.date}} {{summary.type === 'run' ? '跑步' : '骑行'}}</view>
      <view class="main-dist">
        <text class="dist-num">{{summary.distance}}</text>
        <text class="dist-unit">公里</text>
      </view>
      <view class="stats-row">
        <view class="stat">
          <text class="s-val">{{summary.duration}}</text>
          <text class="s-label">时长</text>
        </view>
        <view class="stat">
          <text class="s-val">{{summary.pace}}</text>
          <text class="s-label">平均{{summary.type === 'run' ? '配速' : '速度'}}</text>
        </view>
        <view class="stat">
          <text class="s-val">{{summary.kcal || 320}}</text>
          <text class="s-label">千卡</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Details List -->
  <view class="details-section">
    <view class="section-title">分段配速</view>
    
    <view class="split-list">
      <block wx:for="{{splits}}" wx:key="km">
        <view class="split-item">
          <text class="split-km">{{item.km}}</text>
          <view class="split-bar-container">
            <view class="split-bar {{summary.type}}" style="width: {{item.percent}}%"></view>
          </view>
          <text class="split-pace">{{item.pace}}</text>
        </view>
      </block>
    </view>
  </view>

  <!-- Share Actions -->
  <view class="share-actions">
    <button class="share-btn wx-share" open-type="share">
      <text>微信好友</text>
    </button>
    <button class="share-btn poster-share" bindtap="generatePoster">
      <text>保存海报</text>
    </button>
  </view>

</view>
